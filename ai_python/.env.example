# LLM / OpenAI-compatible (Gemma) — copy to `.env` locally; do not commit secrets.

# Required when LLM_REQUIRED=1 (fail-fast at app startup / registry build).
LLM_REQUIRED=0

LLM_BASE_URL="https://mkp-api.fptcloud.com"
LLM_API_KEY=
LLM_MODEL=gemma-4-31B-it

# Optional: second model for structured JSON + **SQL generation (sql_gen)**.
# Primary LLM_MODEL stays for chat + summarize only.
# Same gateway (mkp-api.fptcloud.com) is fine — only model id changes.
# LLM_STRUCTURED_MODEL=Qwen3.6-27B
# LLM_STRUCTURED_BASE_URL=
# LLM_STRUCTURED_API_KEY=
# LLM_STRUCTURED_TEMPERATURE=0.1

LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=
# LLM_TOP_P=
# LLM_TOP_K=
LLM_STREAMING_DEFAULT=0

# Set to 1 only if the gateway documents support for top_k (avoid HTTP 400).
LLM_SEND_TOP_K=0
# LLM_HTTP_REQUEST_TIMEOUT=120

# --- LangGraph / Task 2 (graph & SQL executor port) ---
# APP_ENV=prod enforces SQL_EXECUTOR_MODE=http_spring
APP_ENV=dev
# Real DB via Spring (Mini ERP): default in GraphSettings matches local smart-erp.
# Offline / unit work only: SQL_EXECUTOR_MODE=stub
SQL_EXECUTOR_MODE=http_spring
# python_ro is deferred post–Task006 Phase 1 — build_sql_executor raises if set without future impl.
# Read-only Postgres for SQL pipeline schema (required): ai_table_description + introspection.
# DATABASE_URL_RO=postgresql://...
# Optional dedicated metadata DSN (defaults to DATABASE_URL_RO when unset):
# DATABASE_URL_METADATA_RO=
# PG_METADATA_SCHEMA=public
# PG_AI_DESCRIPTION_TABLE=ai_table_description
# PG_AI_COLUMN_DESCRIPTION_TABLE=ai_column_description
# PG_METADATA_CONNECT_TIMEOUT_SECONDS=3
SPRING_SQL_URL=http://127.0.0.1:8080/api/v1/ai/db/sql/query-readonly-raw
# SPRING_SQL_BEARER_TOKEN=
# SQL_EXECUTOR_TIMEOUT_SECONDS=10
# SQL_EXECUTOR_ROW_LIMIT=100
# CHECKPOINT_SQLITE_PATH=
MASK_SQL=0
# Log agent steps (intent, SQL, review, SQL row preview) to the server console. Set 0 to reduce noise in prod/tests.
# AGENT_TERMINAL_TRACE=1
# SQL_ALLOWED_TABLES=

# --- Task 3 / Agents v1 ---
# Optional: FileSchemaLoader base dir for unit tests / CLI only (not used by the SQL graph).
# SCHEMA_DIR=
# LIMIT inject ceiling for validate_sql hybrid strategy (rows). Default 1000.
SQL_LIMIT_MAX=1000

# --- Task007 / SQL-Factory–lite (Option B; defaults = Task006 parity when unset/false) ---
# SQL_ENRICHED_SCHEMA_PROMPT=0
# SQL_TABLE_SELECTION_ENABLED=0
# SQL_TABLE_PICK_USE_LLM=0
# SQL_TABLE_PICK_MIN_TABLES_FOR_LLM=6
# SQL_MAX_SELECTED_TABLES=8
# SQL_HYBRID_SIMILARITY_ENABLED=0
# SQL_SIMILARITY_THRESHOLD=0.92
# SQL_SIMILARITY_TOKEN_WEIGHT=0.55
# SQL_LOCAL_POOL_MAX=32
# SQL_EXPLOIT_ON_RETRY=1
# SQL_SEPARATE_SELECT_TABLES_NODE=0
# Recent Human+Assistant turns in gen_sql / SQL summarize prompts (0 = disable tail).
# SQL_DIALOG_TAIL_MAX_MESSAGES=12
# SQL_DIALOG_TAIL_MAX_CHARS=2000
# Summarize: convert ISO timestamps with Z/offset to wall time in this IANA zone (empty = raw JSON).
# AI_DISPLAY_TIMEZONE=Asia/Ho_Chi_Minh

# --- Ledger-first schema explorer (financeledger canonical for revenue/expense) ---
# SQL_SCHEMA_EXPLORER_ENABLED=0
# SQL_SCHEMA_EXPLORER_DESCRIBE_MAX_TABLES=6
# SQL_LEDGER_FIRST_PROMPTS=1
# SQL_VALIDATE_LEDGER_METRIC=1

# --- LLM-first chart pipeline (system_data_chart) ---
# CHART_READINESS_ENABLED=1
# CHART_READINESS_USE_LLM_CRITIC=1
# CHART_BRIEF_CATALOG_MAX_TABLES=40
# CHART_THREAD_CONTEXT_MAX_TURNS=2

# --- Answer quality (final_answer heuristic + optional enrich) ---
# ANSWER_QUALITY_ENABLED=1
# ANSWER_QUALITY_MAX_CHARS=2000
# ANSWER_ENRICH_TIMEOUT_SEC=15

# --- Voice STT (FPT Whisper; uses LLM_BASE_URL + LLM_API_KEY) ---
# STT_ENABLED=0
# STT_MODEL=FPT.AI-whisper-medium
# STT_LANGUAGE=vi
# STT_RESPONSE_FORMAT=json
# STT_MAX_AUDIO_SECONDS=60
# STT_MAX_UPLOAD_BYTES=10485760
# STT_HTTP_TIMEOUT_SECONDS=45

# --- Voice TTS (FPT VITs; uses LLM_BASE_URL + LLM_API_KEY) ---
# TTS_ENABLED=0
# TTS_MODEL=FPT.AI-VITs
# TTS_VOICE=std_kimngan
# TTS_RESPONSE_FORMAT=wav
# TTS_MAX_INPUT_CHARS=5000
# TTS_HTTP_TIMEOUT_SECONDS=60

# --- Task 4 / FastAPI trust-boundary auth ---
# Default is strict auth. Use bypass only for local tests.
AUTH_DEV_BYPASS=0
# HS256 — same secret as Spring `app.security.jwt.secret` / JWT_SECRET (UTF-8, >= 32 bytes).
# JWT_HS256_SECRET=
JWT_ISSUER=
JWT_AUDIENCE=
# Configure one key source (when not using JWT_HS256_SECRET):
# JWT_JWKS_URL=
# JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
