# ===== Agentic AI (ai_python) — .env template =====
# Copy file nay thanh `.env` roi dien gia tri. `.env` da bi gitignore (khong commit).
#   cp .env.example .env   (hoac copy tay tren Windows)

# --- Auth (JWT HS256) ---
AUTH_DEV_BYPASS=0
JWT_HS256_SECRET=
JWT_ISSUER=
JWT_AUDIENCE=

# --- LLM: Qwen3.6-27B qua FPT Cloud (OpenAI-compatible) ---
LLM_BASE_URL=https://mkp-api.fptcloud.com
# >>> DAN API KEY FPT CLOUD VAO DAY <<<
LLM_API_KEY=
LLM_MODEL=Qwen3.6-27B
LLM_TEMPERATURE=0.2            # nhiet do cho cac tool
LLM_SM_TEMPERATURE=0.0         # Session Manager: structured JSON -> deterministic
LLM_HTTP_REQUEST_TIMEOUT=120
LLM_STRUCTURED_MODEL=gemma-4-26B-A4B-it   # escape hatch, CHUA wire

# --- SQL: direct read-only Postgres ---
DATABASE_URL_RO=postgresql://USER:PASSWORD@127.0.0.1:5432/DBNAME
SQL_ROW_LIMIT=100
SQL_EXEC_TIMEOUT_SECONDS=10

# --- Harness / budget ---
HARNESS_MAX_STEPS=6
TOOL_RETRY_CAP=2
HITL_CHECKPOINT_DB=./var/hitl_checkpoints.sqlite

APP_ENV=dev
