# LLM / OpenAI-compatible (Gemma) — copy to `.env` locally; do not commit secrets.

# Required when LLM_REQUIRED=1 (fail-fast at app startup / registry build).
LLM_REQUIRED=0

LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gemma-4-31B-it

LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=
# LLM_TOP_P=
# LLM_TOP_K=
LLM_STREAMING_DEFAULT=0

# Set to 1 only if the gateway documents support for top_k (avoid HTTP 400).
LLM_SEND_TOP_K=0

# --- LangGraph / Task 2 (graph & SQL executor port) ---
# APP_ENV=prod enforces SQL_EXECUTOR_MODE=http_spring
APP_ENV=dev
# allowed: stub | python_ro | http_spring
SQL_EXECUTOR_MODE=stub
# DATABASE_URL_RO=
# SPRING_SQL_URL=
# CHECKPOINT_SQLITE_PATH=
MASK_SQL=0
# SQL_ALLOWED_TABLES=

# --- Task 3 / Agents v1 ---
# Schema artifact directory (defaults to packaged ai_python/app/data/schema/)
SCHEMA_DIR=
# LIMIT inject ceiling for validate_sql hybrid strategy (rows). Default 1000.
SQL_LIMIT_MAX=1000

# --- Task 4 / FastAPI trust-boundary auth ---
# Default is strict auth. Use bypass only for local tests.
AUTH_DEV_BYPASS=0
JWT_ISSUER=
JWT_AUDIENCE=
# Configure one key source:
# JWT_JWKS_URL=
# JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
